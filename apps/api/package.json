{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": ".venv/bin/uvicorn main:app --reload --port 3001 --host 0.0.0.0",
    "start": ".venv/bin/uvicorn main:app --port 3001 --host 0.0.0.0",
    "start:cluster": ".venv/bin/uvicorn main:app --port 3001 --host 0.0.0.0 --workers 4",
    "setup": "python3.11 -m venv .venv && .venv/bin/pip install -r requirements.txt && .venv/bin/python -m spacy download de_core_news_md",
    "worker": "PYTHONPATH=. .venv/bin/python run_workers.py"
  }
}
