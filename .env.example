# In das Repo-Root legen: `cp .env.example .env` — `apps/web/next.config.mjs` lädt diese Werte
# (lauter nur `apps/web/.env*`, dann fehlt oft DATABASE_URL und Auth antwortet mit 500).
#
# Next.js läuft nicht im Docker-Stack, sondern auf dem Host mit Hot Reload:
#   bun run dev:web   (Port 3000, Turbopack)
# Stack parallel:    docker compose up -d
#
# Lokal: Postgres starten, z. B. `docker compose up -d postgres`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pdf_anonym
#
# Docker (Web-Container nutzt die gleiche DB): Ohne Migration + Seed schlagen /api/auth/*
# mit 500 fehl (Tabellen fehlen). Einmalig nach `docker compose up` auf dem Host, wenn
# Postgres auf 127.0.0.1:5432 erreichbar ist:
#   bun run db:setup:docker
# (legt laut db:seed u. a. user@pdffabrik.de + admin@pdffabrik.de an; Passwörter: packages/prisma/seed)

# Better Auth — in Produktion kryptographisch zufällig (mind. 32 Zeichen) setzen
BETTER_AUTH_SECRET=7f2c9a1b4d8e3c6f0a2b4d6e8f0a1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b

# Next.js-Origin (Cookies, Callbacks, SEO metadataBase / Open Graph). Lokal: localhost; live: https://pdffabrik.de
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# PDF-Worker (Coolify docker-compose-cf.yml): parallele RQ-Jobs für pdf-redact / pdf-redact-json
# WORKER_REPLICAS=4
# PII_PRESIDIO_MAX_WORKERS=6
# OMP_NUM_THREADS=4

# Gemeinsames Geheimnis Next.js ↔ FastAPI (Produktion Pflicht). Gleicher Wert in Web- und API-Container.
# openssl rand -hex 32
# PDF_INTERNAL_SERVICE_TOKEN=

# FastAPI (PyMuPDF) — Client + serverseitige Routen (z. B. pdf-proxy, Integrationen)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Nur Server (Next-API-Routes, pdf-proxy). Coolify Web-App, Backend im gleichen Stack:
# PDF_TOOL_API_URL=http://api:3001
# Lokal mit docker compose (Web auf Host, API im Container):
# PDF_TOOL_API_URL=http://127.0.0.1:3001
#
# Browser → PDF-API: standardmäßig same-origin (`/api/pdf-proxy/v1/*` Route-Handler mit Auth).
# Kein Cross-Origin zu :3001. Direkte URL erzwingen (CORS nötig):
# NEXT_PUBLIC_PDF_API_SAME_ORIGIN=0
#
# FastAPI CORS: nur nötig bei NEXT_PUBLIC_PDF_API_SAME_ORIGIN=0 oder externen Apps, die :3001
# direkt im Browser ansprechen. Status (null) oft = API nicht erreichbar, nicht nur CORS.
# Zusätzliche Origins (kommagetrennt), z. B. LAN-IP:
# PDF_API_CORS_ORIGINS=http://192.168.1.5:3000

# API-Schlüssel (Integration /api/v1/integrations/pdf-detect): Hashing. Optional — wenn leer, wird
# BETTER_AUTH_SECRET verwendet (mind. 16 Zeichen).
# PDFFABRIK_API_TOKEN_PEPPER=
# Optional: Browser-CORS für die Integration-Route. Leer = nur Server-zu-Server.
# Kommagetrennte Origins oder * für alle Browser-Origins.
# INTEGRATION_CORS_ORIGINS=https://partner.example.com,http://localhost:5173
# INTEGRATION_CORS_ORIGINS=*

# Optional: Test-Nutzer aus `bun run db:seed` (Default-Passwörter: pdffabrikdev)
# SEED_USER_EMAIL=user@pdffabrik.de
# SEED_USER_PASSWORD=pdffabrikdev
# SEED_USER_NAME=User
# SEED_ADMIN_EMAIL=admin@pdffabrik.de
# SEED_ADMIN_PASSWORD=pdffabrikdev
# SEED_ADMIN_NAME=Admin

# Ollama (simple-detect LLM-Ergänzung): nur serverseitig — nicht NEXT_PUBLIC_*
# OLLAMA_BASE_URL=https://dein-ollama-host:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=dein_api_key
# OLLAMA_AUTH_USER=maxcheck_user
