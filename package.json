{
  "name": "pdffabrik",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:web": "bun run --filter web dev",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "db:generate": "bun run --filter @workspace/prisma build",
    "db:migrate": "bun run --filter @workspace/prisma migrate:deploy",
    "db:migrate:docker": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pdf_anonym bun run --filter @workspace/prisma migrate:deploy",
    "db:setup:docker": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pdf_anonym bun run --filter @workspace/prisma migrate:deploy && DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pdf_anonym bun run --filter @workspace/prisma seed",
    "db:push": "bun run --filter @workspace/prisma db:push",
    "db:seed": "bun run --filter @workspace/prisma seed",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.2.18",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
